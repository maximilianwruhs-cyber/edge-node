{
  "$schema": "https://docs.openclaw.ai/schema.json",
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "REPLACE_ME_RUN_INSTALL_NODE_SH"
    }
  },
  "models": {
    "providers": {
      "gemini": {
        "apiKey": "REPLACE_ME_GEMINI_API_KEY",
        "models": [
          {
            "id": "gemini-2.5-flash",
            "name": "Gemini 2.5 Flash (Cloud)"
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/workspace/core_identity",
      "model": "gemini/gemini-2.5-flash"
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "groupPolicy": "disabled"
    }
  },
  "mcp": {
    "servers": {
      "obsidian-vault": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-filesystem", "/workspace/Obsidian_Vault"]
      },
      "qmd-search": {
        "command": "qmd",
        "args": ["mcp"]
      }
    }
  },
  "plugins": {
    "entries": {
      "acpx": {
        "enabled": true
      }
    }
  }
}
