# ── GZMO Daemon Configuration ──────────────────────────────────
# Copy this file to .env and adjust values for your setup.
#   cp .env.example .env

# Path to your Obsidian Vault (required — adjust to your system)
VAULT_PATH=/path/to/Obsidian_Vault

# Ollama model for inference (default: qwen2.5:3b)
OLLAMA_MODEL=qwen2.5:3b

# Ollama API endpoint (default: http://localhost:11434/v1)
OLLAMA_URL=http://localhost:11434/v1

# ── Ollama Performance Tuning (set these when starting ollama serve) ──
# OLLAMA_KV_CACHE_TYPE=q8_0       # KV cache quantization (saves ~50% VRAM)
# OLLAMA_FLASH_ATTENTION=1         # Enable flash attention
# OLLAMA_KEEP_ALIVE=-1             # Keep model in VRAM forever
