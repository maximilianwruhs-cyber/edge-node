# ============================================================
# GZMO Edge-Node — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Or run ./install_node.sh to generate it automatically.
# ============================================================

# ── Paths ──
# Absolute path to your Obsidian Vault on the host machine.
# The vault is mounted into the container for MCP filesystem access.
OBSIDIAN_VAULT_PATH=/path/to/your/Obsidian_Vault

# ── API Keys ──
# Gemini API Key (required) — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Telegram Bot Token (required) — get one from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# OpenRouter API Key (optional) — for model failover
OPENROUTER_API_KEY=

# SerpAPI Key (optional) — for grounded web search in Chaos Engine research
SERPAPI_API_KEY=

# ── Internal Security ──
# Auto-generated auth token for the OpenClaw gateway.
# If left empty, install_node.sh will generate one for you.
OPENCLAW_AUTH_TOKEN=
